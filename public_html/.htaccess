# ─────────────────────────────────────────────────────────────────────────────
# Edarat365 — Production hardening (cPanel/Apache)
# ─────────────────────────────────────────────────────────────────────────────

# Disable directory browsing and signature, but allow following symlinks so the
# `public_html/storage` symlink (→ laravel-app/storage/app/public) is honored
# when serving uploaded images/documents directly via Apache.
Options -Indexes -MultiViews +SymLinksIfOwnerMatch +FollowSymLinks
ServerSignature Off

# ─── SPA Routing ─────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Don't rewrite API requests
    RewriteRule ^api/ - [L]

    # /storage/<...> is served directly by Apache via the public_html/storage
    # symlink that points at laravel-app/storage/app/public (created by
    # setup.sh / .cpanel.yml). The previous rewrite to /api/storage/$1 was a
    # dead end because Laravel does not expose /api/storage/{path} — and the
    # SPA fallback at the bottom would then swallow the request and return
    # index.html, breaking every uploaded image. We rely on the
    # `REQUEST_FILENAME -f` checks below to send these to the symlinked file.

    # Block path traversal attempts
    RewriteCond %{THE_REQUEST} \s/+(.*)\.\.(.*)\s [NC]
    RewriteRule ^ - [F,L]

    # Don't rewrite real files or directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Send everything else to index.html (Vue Router will handle it)
    RewriteRule ^ index.html [L]
</IfModule>

# ─── Security Headers (defense-in-depth) ─────────────────────────────────────
<IfModule mod_headers.c>
    # Force HTTPS for one year, on all subdomains, eligible for browser preload list
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Block search engines (private platform)
    Header always set X-Robots-Tag "noindex, nofollow, noarchive, nosnippet, noimageindex, nocache"

    # Click-jacking protection — SAMEORIGIN (not DENY) so the SPA can iframe
    # uploaded PDFs/images served from /storage/* on the same origin. External
    # sites are still blocked from embedding us.
    Header always set X-Frame-Options "SAMEORIGIN"

    # MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Referrer leakage
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Disable powerful browser APIs we never use
    Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"

    # Cross-origin isolation
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-site"

    # Content-Security-Policy: relaxed enough for the SPA (inline + Google Fonts)
    # script-src-elem is set explicitly so Cloudflare's analytics beacon (auto-injected
    # at the edge) is not blocked when the domain is proxied through Cloudflare.
    # frame-ancestors 'self' (not 'none') so /storage/*.pdf can be embedded
    # by the SPA in iframes (PDF preview). External origins still cannot
    # frame us.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://static.cloudflareinsights.com; script-src-elem 'self' 'unsafe-inline' 'unsafe-eval' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https: https://cloudflareinsights.com; frame-ancestors 'self'; form-action 'self'; base-uri 'self'; object-src 'none'; media-src 'self'; worker-src 'self' blob:;"

    # Hide server software fingerprint
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ─── Block sensitive files & directories ─────────────────────────────────────
# Anything starting with a dot (.git, .env, .htaccess itself, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Common sensitive extensions
<FilesMatch "\.(env|log|sql|sqlite|sqlite3|bak|backup|swp|swo|orig|save|pem|key|crt|p12|pfx|md|lock|config|inc|tpl|tar|tar\.gz|tgz|zip|7z|rar)$">
    Require all denied
</FilesMatch>

# Composer / npm metadata files
<FilesMatch "(composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|webpack\.config\..*|vite\.config\..*|\.eslintrc.*|\.prettierrc.*|tsconfig.*|phpunit\.xml|README\.md|CHANGELOG.*|LICENSE.*)$">
    Require all denied
</FilesMatch>

# Block any access to vendor / framework / build paths.
# Note: /storage is intentionally allowed here so user-upload URLs like
# /storage/properties/<id>/documents/<file> work via the rewrite to /api/storage above.
# Backend storage internals (framework, logs, etc.) are protected on the API side.
RedirectMatch 404 /(vendor|bootstrap/cache|node_modules|tests|database|config|app|routes|resources)(/|$)

# ─── Compression ─────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/xml+rss image/svg+xml
</IfModule>

# ─── Cache static assets ─────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>
