# ─────────────────────────────────────────────────────────────────────────────
# Edarat365 API — Laravel public/ entry hardening
# ─────────────────────────────────────────────────────────────────────────────

Options -MultiViews -Indexes
ServerSignature Off

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block path traversal
    RewriteCond %{THE_REQUEST} \s/+(.*)\.\.(.*)\s [NC]
    RewriteRule ^ - [F,L]

    # Handle Authorization Header (cPanel + PHP-FPM compatibility)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Trailing slashes
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Front-controller pattern
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# ─── Security Headers ────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ─── Block access to dotfiles ────────────────────────────────────────────────
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# ─── Block sensitive file extensions ─────────────────────────────────────────
<FilesMatch "\.(env|log|sql|sqlite|sqlite3|bak|backup|swp|swo|orig|save|pem|key|crt|p12|pfx|md|lock|composer\.json|composer\.lock|package\.json|yarn\.lock|phpunit\.xml|inc|tpl)$">
    Require all denied
</FilesMatch>
