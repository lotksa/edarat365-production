# ─────────────────────────────────────────────────────────────────────────────
# Edarat365 — Production environment template (.env.production.example)
#
# IMPORTANT
# ─────────────────────────────────────────────────────────────────────────────
# 1. NEVER commit a real .env.production. This file is a template only.
# 2. Replace every occurrence of "CHANGE_ME_..." with a strong unique secret
#    BEFORE deploying. The deploy will REFUSE to boot if any CHANGE_ME_*
#    placeholder remains (validated in bootstrap/app.php).
# 3. Generate APP_KEY via: php artisan key:generate
# 4. Use a secrets manager / vault in production. This file is for reference.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=Edarat365
APP_ENV=production
APP_KEY=base64:CHANGE_ME_RUN_php_artisan_key_generate_THEN_REPLACE
APP_DEBUG=false
APP_URL=https://CHANGE_ME_DOMAIN
FRONTEND_URL=https://CHANGE_ME_DOMAIN

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA
APP_MAINTENANCE_DRIVER=file
APP_TIMEZONE=Asia/Riyadh

# Higher rounds = slower but harder to brute force. 12 is the sane default
# for modern hardware; do not lower. Legacy was 10.
BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=30

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=CHANGE_ME_DB_NAME
DB_USERNAME=CHANGE_ME_DB_USER
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# Sessions: keep encrypted in case the file/redis backend is ever leaked.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=CHANGE_ME_DOMAIN
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=edarat365_

# Redis is OPTIONAL. Only set REDIS_PASSWORD if Redis itself is configured.
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
# REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME_SMTP_USER
MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@CHANGE_ME_DOMAIN"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum / SPA hosts — comma-separated, no scheme.
SANCTUM_STATEFUL_DOMAINS=CHANGE_ME_DOMAIN

# CORS allowed origins (comma-separated). Avoid using "*" with credentials.
CORS_ALLOWED_ORIGINS=https://CHANGE_ME_DOMAIN

# Trust proxy headers from Cloudflare/cPanel reverse proxy.
TRUSTED_PROXIES=*

# Seed-only: leave empty in production. The first deploy will print a random
# admin password to storage/app/seeded-admin-credentials.txt — change it on
# first login and delete the file.
SEED_ADMIN_PASSWORD=

VITE_APP_NAME="${APP_NAME}"
